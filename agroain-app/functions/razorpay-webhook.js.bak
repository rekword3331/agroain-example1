// पुरानी lines (इन्हें हटा दें):
// const firebaseUrl = `https://agroain-default-rtdb.firebaseio.com/orders/${orderId}.json`;
// await fetch(firebaseUrl, { method: 'PATCH', ... });

// ✅ नई lines (ये डालें):
const paymentId = payment.id; // Razorpay से आया हुआ paymentId
const firebaseUrl = `https://agroain-default-rtdb.firebaseio.com/successful_orders/${paymentId}.json`;

// पहले चेक करें कि कहीं Frontend ने पहले से तो सेव नहीं कर दिया
const checkRes = await fetch(firebaseUrl, { method: 'GET' });
const existingData = await checkRes.json();

if (existingData && existingData.status === "Paid / Confirmed") {
    // अगर Frontend ने पहले से सेव कर दिया है, तो सिर्फ Webhook Verified का टैग लगा दें
    await fetch(firebaseUrl, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ webhook_verified: true, webhook_time: new Date().toISOString() })
    });
    console.log(`✅ Webhook verified existing order for ${paymentId}`);
} else {
    // अगर Frontend नहीं चला (क्योंकि ब्राउज़र बंद था), तो Webhook पूरा डेटा सेव करेगा
    const orderData = {
        paymentId: paymentId,
        // customerName, phone, address को हटा दें क्योंकि ये notes में नहीं हैं
        itemName: payment.description || "Agroain Product",
        amountPaid: payment.amount / 100,
        status: "Paid (Webhook)",
        timestamp: new Date().toISOString(),
        webhook_verified: true
    };
    await fetch(firebaseUrl, {
        method: 'PUT', // PUT पूरा डेटा सेट करेगा
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(orderData)
    });
    console.log(`✅ Webhook created fallback order for ${paymentId}`);
}